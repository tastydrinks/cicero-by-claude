# LaTeX build artefacts
build/*.aux
build/*.log
build/*.toc
build/*.out
build/*.idx
build/*.ind
build/*.ilg
build/*.xdv
build/*.fls
build/*.fdb_latexmk
build/*.synctex.gz
build/*.upa
build/*.upb

# generated tex files (regenerated by scripts/assemble_book.py,
# scripts/build_manifest.py, and scripts/generate_backmatter.py)
build/body.tex
build/chronology.tex
build/backmatter-generated.tex

# preprocessed (hyperlink-wrapped) English files: regenerated on every
# build by scripts/preprocess_english.py from the source english/ files
build/english/

# generated PDFs except final tagged releases
build/output/*.pdf
!build/output/cicero-v*.pdf

# python
__pycache__/
*.pyc
.venv/
.env

# editor cruft
.DS_Store
*.swp
*.swo
.vscode/
.idea/
build/cicero.pdf

# web edition (Astro)
web/dist/
web/node_modules/
web/.astro/
