    {"loc": "12", "surface": "Then a decree of the Senate is passed", "entity_id": "institution:senate", "in": "eng"},
    {"loc": "12", "surface": "Scaptius draws me aside", "entity_id": "person:m-scaptius", "in": "eng"},
    {"loc": "12", "surface": "with Scaptius withdrawn", "entity_id": "person:m-scaptius", "in": "eng"},
    {"loc": "12", "surface": "I refer the matter back to Scaptius", "entity_id": "person:m-scaptius", "in": "eng"},
    {"loc": "12", "surface": "The Salaminians say they wish to pay", "entity_id": "place:salamis-cyprus", "in": "eng"},
    {"loc": "12", "surface": "Scaptius draws me aside again", "entity_id": "person:m-scaptius", "in": "eng"},
    {"loc": "12", "surface": "more shameless than Scaptius", "entity_id": "person:m-scaptius", "in": "eng"},

