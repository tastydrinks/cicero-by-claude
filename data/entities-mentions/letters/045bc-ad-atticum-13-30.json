  "mentions": [
    {"loc": "1", "surface": "ad te miseram Demean", "entity_id": "person:demeas", "in": "lat"},
    {"loc": "1", "surface": "quom Eros ad me venit", "entity_id": "person:eros-atticianus", "in": "lat"},
    {"loc": "1", "surface": "negat Eros hodie", "entity_id": "person:eros-atticianus", "in": "lat"},
    {"loc": "1", "surface": "confecto negotio Faberiano", "entity_id": "person:faberius", "in": "lat"},
    {"loc": "1", "surface": "I had just dispatched Demeas to you", "entity_id": "person:demeas", "in": "eng"},
    {"loc": "1", "surface": "when Eros came to me", "entity_id": "person:eros-atticianus", "in": "eng"},
    {"loc": "1", "surface": "Eros says it cannot be today", "entity_id": "person:eros-atticianus", "in": "eng"},
    {"loc": "1", "surface": "I should like the Faberian business wrapped up too", "entity_id": "person:faberius", "in": "eng"},
    {"loc": "2", "surface": "qui decem legati Mummio fuerint", "entity_id": "person:l-mummius-achaicus", "in": "lat"},
