{
  "schema_version": 1,
  "id": "ad-atticum-13-25",
  "mentions": [
    {"loc": "1", "surface": "de Andromene ut scribis", "entity_id": "person:andromenes", "in": "lat"},
    {"loc": "1", "surface": "ita mihi de Bruto scribis", "entity_id": "person:brutus", "in": "lat"},
    {"loc": "1", "surface": "ego Romam pridie Idus", "entity_id": "place:roma", "in": "lat"},
    {"loc": "1", "surface": "Bruto ita volui scribere", "entity_id": "person:brutus", "in": "lat"},
    {"loc": "1", "surface": "me quasi prosequendi sui causa Romam nunc venire", "entity_id": "place:roma", "in": "lat"},
    {"loc": "1", "surface": "in Tusculano sit", "entity_id": "place:tusculum", "in": "lat"},
    {"loc": "1", "surface": "ne ob eam causam Romam venisse videar", "entity_id": "place:roma", "in": "lat"},
    {"loc": "1", "surface": "scripsi igitur ad Brutum", "entity_id": "person:brutus", "in": "lat"},
    {"loc": "1", "surface": "ne minima quidem re ulla Bruti commodum impediamus", "entity_id": "person:brutus", "in": "lat"},
    {"loc": "1", "surface": "About Andromenes", "entity_id": "person:andromenes", "in": "eng"},
    {"loc": "1", "surface": "you write to me about Brutus", "entity_id": "person:brutus", "in": "eng"},
    {"loc": "1", "surface": "at Rome on the day before the Ides", "entity_id": "place:roma", "in": "eng"},
    {"loc": "1", "surface": "To Brutus I had meant to write", "entity_id": "person:brutus", "in": "eng"},
    {"loc": "1", "surface": "to come to Rome now as if it were to escort him", "entity_id": "place:roma", "in": "eng"},
    {"loc": "1", "surface": "from being at Tusculum", "entity_id": "place:tusculum", "in": "eng"},
    {"loc": "1", "surface": "to have come to Rome on that account", "entity_id": "place:roma", "in": "eng"},
    {"loc": "1", "surface": "I have already written to Brutus", "entity_id": "person:brutus", "in": "eng"},
    {"loc": "1", "surface": "we obstruct Brutus's convenience", "entity_id": "person:brutus", "in": "eng"},
    {"loc": "3", "surface": "libros dari Varroni", "entity_id": "person:m-terentius-varro", "in": "lat"},
    {"loc": "3", "surface": "volo Varronem", "entity_id": "person:m-terentius-varro", "in": "lat"},
    {"loc": "3", "surface": "si quando in Epirum veneris", "entity_id": "place:epirus", "in": "lat"},
    {"loc": "3", "surface": "nunc Alexionis epistulis cedimus", "entity_id": "person:alexio", "in": "lat"},
    {"loc": "3", "surface": "non despero probatum iri Varroni", "entity_id": "person:m-terentius-varro", "in": "lat"},
    {"loc": "3", "surface": "ad Brutum transeamus", "entity_id": "person:brutus", "in": "lat"},
    {"loc": "3", "surface": "est enim is quoque Antiochius", "entity_id": "person:antiochus-ascalon", "in": "lat"},
    {"loc": "3", "surface": "o Academiam volaticam", "entity_id": "place:academia-athens", "in": "lat"},
    {"loc": "3", "surface": "epistula mea ad Varronem", "entity_id": "person:m-terentius-varro", "in": "lat"},
    {"loc": "3", "surface": "ne Tironi quidem dictavi", "entity_id": "person:tiro", "in": "lat"},
    {"loc": "3", "surface": "sed Spintharo syllabatim", "entity_id": "person:spintharus", "in": "lat"},
    {"loc": "3", "surface": "the books be given to Varro", "entity_id": "person:m-terentius-varro", "in": "eng"},
    {"loc": "3", "surface": "I want Varro to have them", "entity_id": "person:m-terentius-varro", "in": "eng"},
    {"loc": "3", "surface": "if ever you come to Epirus", "entity_id": "place:epirus", "in": "eng"},
    {"loc": "3", "surface": "we yield place to Alexio's letters", "entity_id": "person:alexio", "in": "eng"},
    {"loc": "3", "surface": "will meet with Varro's approval", "entity_id": "person:m-terentius-varro", "in": "eng"},
    {"loc": "3", "surface": "let us cross over to Brutus", "entity_id": "person:brutus", "in": "eng"},
    {"loc": "3", "surface": "for he too is an Antiochean", "entity_id": "person:antiochus-ascalon", "in": "eng"},
    {"loc": "3", "surface": "O the flighty Academy", "entity_id": "place:academia-athens", "in": "eng"},
    {"loc": "3", "surface": "did my letter to Varro really please you", "entity_id": "person:m-terentius-varro", "in": "eng"},
    {"loc": "3", "surface": "I did not even dictate it to Tiro", "entity_id": "person:tiro", "in": "eng"},
    {"loc": "3", "surface": "but to Spintharus, syllable by syllable", "entity_id": "person:spintharus", "in": "eng"}
  ]
}
