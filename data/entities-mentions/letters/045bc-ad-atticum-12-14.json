    {"loc": "1", "surface": "and Statilius", "entity_id": "person:l-statilius", "in": "eng"},
    {"loc": "1", "surface": "Laenas, though, had taken the whole business on himself", "entity_id": "person:laenas", "in": "eng"},
    {"loc": "2", "surface": "omnino Cornificius locuples est", "entity_id": "person:q-cornificius", "in": "lat"},
    {"loc": "2", "surface": "procuratores Cornifici et Appuleium praediatorem videbis", "entity_id": "person:q-cornificius", "in": "lat"},
    {"loc": "2", "surface": "procuratores Cornifici et Appuleium praediatorem videbis", "entity_id": "person:m-appuleius", "in": "lat"},
    {"loc": "2", "surface": "Cornificius is, in any case, a man of means", "entity_id": "person:q-cornificius", "in": "eng"},
    {"loc": "2", "surface": "you will see Cornificius's agents", "entity_id": "person:q-cornificius", "in": "eng"},
    {"loc": "2", "surface": "and Appuleius the auctioneer", "entity_id": "person:m-appuleius", "in": "eng"},
    {"loc": "4", "surface": "de Bruti ad me litteris scripsi ad te antea", "entity_id": "person:brutus", "in": "lat"},
    {"loc": "4", "surface": "maxime autem Pansa quando", "entity_id": "person:vibius-pansa", "in": "lat"},
