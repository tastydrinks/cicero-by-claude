    {"loc": "1", "surface": "sed mihi Laenas totum receperat", "entity_id": "person:laenas", "in": "lat"},
    {"loc": "1", "surface": "About my being excused before Appuleius", "entity_id": "person:m-appuleius", "in": "eng"},
    {"loc": "1", "surface": "But see to Septimius", "entity_id": "person:c-septimius", "in": "eng"},
