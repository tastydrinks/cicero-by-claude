  "mentions": [
    {"loc": "1", "surface": "putas mihi dixisse Balbum et Faberium", "entity_id": "person:l-cornelius-balbus", "in": "lat"},
    {"loc": "1", "surface": "Balbum et Faberium professionem relatam", "entity_id": "person:faberius", "in": "lat"},
    {"loc": "1", "surface": "professus est Philotimus libertus", "entity_id": "person:philotimus", "in": "lat"},
    {"loc": "1", "surface": "Balbus and Faberius told me only once", "entity_id": "person:l-cornelius-balbus", "in": "eng"},
    {"loc": "1", "surface": "Balbus and Faberius told me only once", "entity_id": "person:faberius", "in": "eng"},
    {"loc": "1", "surface": "My freedman Philotimus has made the declaration", "entity_id": "person:philotimus", "in": "eng"},
    {"loc": "2", "surface": "ad Faberium, ut tibi placet, litteras misi", "entity_id": "person:faberius", "in": "lat"},
    {"loc": "2", "surface": "cum Balbo autem puto te aliquid fecisse", "entity_id": "person:l-cornelius-balbus", "in": "lat"},
    {"loc": "2", "surface": "†H in Capitolio†", "entity_id": "place:capitolium", "in": "lat"},
    {"loc": "2", "surface": "in Vergilio mihi nulla est", "entity_id": "person:c-vergilius", "in": "lat"},
    {"loc": "2", "surface": "ne is tum sit in Africa ut Caelius", "entity_id": "place:africa", "in": "lat"},
    {"loc": "2", "surface": "de nomine tu videbis cum Cispio", "entity_id": "person:cispius", "in": "lat"},
    {"loc": "2", "surface": "sed si Plancus destinat", "entity_id": "person:munatius-plancus", "in": "lat"},
    {"loc": "2", "surface": "Othonem quod speras posse vinci", "entity_id": "person:otho", "in": "lat"},
    {"loc": "2", "surface": "Dicaearchi librum accepi", "entity_id": "person:dicaearchus", "in": "lat"},
    {"loc": "2", "surface": "I have sent a letter to Faberius", "entity_id": "person:faberius", "in": "eng"},
    {"loc": "2", "surface": "with Balbus, however, I imagine you have done something", "entity_id": "person:l-cornelius-balbus", "in": "eng"},
    {"loc": "2", "surface": "\\dag{}H in Capitolio\\dag{}", "entity_id": "place:capitolium", "in": "eng"},
    {"loc": "2", "surface": "About Vergilius I feel no embarrassment", "entity_id": "person:c-vergilius", "in": "eng"},
    {"loc": "2", "surface": "that he is not then in Africa, as Caelius is", "entity_id": "place:africa", "in": "eng"},
    {"loc": "2", "surface": "you will look into it with Cispius", "entity_id": "person:cispius", "in": "eng"},
    {"loc": "2", "surface": "but if Plancus is fixed on it", "entity_id": "person:munatius-plancus", "in": "eng"},
    {"loc": "2", "surface": "That you hope Otho can be beaten down", "entity_id": "person:otho", "in": "eng"},
    {"loc": "2", "surface": "I have received Dicaearchus's book", "entity_id": "person:dicaearchus", "in": "eng"},
    {"loc": "3", "surface": "L. Mummio coss", "entity_id": "person:l-mummius-achaicus", "in": "lat"},
    {"loc": "3", "surface": "de Tuditano autem quod putas", "entity_id": "person:c-sempronius-tuditanus-cos129", "in": "lat"},
